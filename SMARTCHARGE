--  §44  CROSS-SHARD / WORLD-TRANSFER GUARD
--  If a player changes shard/world mid-charge (TC3 battleground transfer),
--  abort the charge immediately.
-- =============================================================================

local function OnPlayerEnterWorld(event, player)
    -- Speed exploit guard on map changes
    SanitizePlayerSpeed(player)

    -- If there's an active charge state for a player who just entered the
    -- world (meaning they came from another map), abort it.
    local state = StateGet(player)
    if state and state.active then
        AbortCharge(player, state, "world transfer during charge")
        StateRemove(player)
    end
end

-- PLAYER_EVENT_ON_LOGIN = 3 (also fires on zone transfer in some builds)
RegisterPlayerEvent(3, function(event, player)
    if player.IsBot and player:IsBot() then return end
    return OnPlayerEnterWorld(event, player)
end)

-- =============================================================================
--  §45  MOVEMENT FLAGS INSPECTOR
--  In WotLK 3.3.5a, unit movement flags determine whether a charge is
--  currently physically possible.  We inspect them before issuing movement.
-- =============================================================================

-- Bug 8 fix: bit.band() requires the BitOp library (not part of standard
-- Lua 5.1).  Load it explicitly; if unavailable, provide a pure-Lua fallback
-- so the rest of the module doesn't crash on servers without luabitop.
local _bit = (type(bit) == "table" and bit) or
             (pcall(require, "bit") and require("bit")) or
             nil

local function _band(a, b)
    if _bit then return _bit.band(a, b) end
    -- Fallback: pure-Lua 32-bit AND (correct for flag checks used here)
    local result = 0
    local pow    = 1
    for _ = 1, 32 do
        if a % 2 >= 1 and b % 2 >= 1 then
            result = result + pow
        end
        a   = math.floor(a / 2)
        b   = math.floor(b / 2)
        pow = pow * 2
    end
    return result
end

-- Movement flag constants (partial list from TC3 MovementFlags)
local MOVEFLAGS = {
    NONE           = 0x00000000,
    FORWARD        = 0x00000001,
    BACKWARD       = 0x00000002,
    STRAFE_LEFT    = 0x00000004,
    STRAFE_RIGHT   = 0x00000008,
    TURN_LEFT      = 0x00000010,
    TURN_RIGHT     = 0x00000020,
    PITCH_UP       = 0x00000040,
    PITCH_DOWN     = 0x00000080,
    SWIMMING       = 0x00200000,
    ASCENDING      = 0x00400000,  -- Swimming upward
    DESCENDING     = 0x00800000,  -- Swimming downward
    FLYING         = 0x01000000,
    DISABLE_GRAVITY = 0x00000200,
    ROOT           = 0x00040000,  -- Player is rooted
    FALLING        = 0x00002000,  -- MOVEMENTFLAG_FALLING in TC3
}

--- Check whether a player's movement flags prevent charging.
CanChargeByMoveFlags = function(player)
    local ok, flags = pcall(function() return player:GetMovementFlags() end)
    if not ok then return true end  -- Assume can charge if API missing

    -- Cannot charge while flying
    if _band(flags, MOVEFLAGS.FLYING) ~= 0 then
        return false, "flying"
    end
    -- Bug 14 fix: block charge while jumping / in the air
    if _band(flags, MOVEFLAGS.FALLING) ~= 0 then
        return false, "jumping"
    end
    -- Cannot charge while rooted (should be caught by TC, but double-check)
    -- Note: MOVEFLAGS.ROOT is not always reliable in Eluna; keep as advisory
    -- Cannot charge while swimming above surface
    if _band(flags, MOVEFLAGS.ASCENDING) ~= 0 then
        return false, "ascending_in_water"
    end

    return true, nil
end

-- =============================================================================
--  §46  SAFE-FALL PROTECTION FOR CHARGE LANDING
--  If the destination Z is significantly lower than the player's current Z,
--  apply a safe-fall effect to prevent fall damage on landing.
--  NOTE: The actual application is inlined into ApplyLandingEffects (§18+19+46
--  merged) rather than via a monkey-patch chain.
-- =============================================================================

local FALL_SAFE_AURA       = 1706   -- Levitate as a temporary safe-fall
local FALL_DAMAGE_THRESHOLD = 8.0   -- More than 8 yards of fall = apply protection

-- =============================================================================
--  §47  SWIM-PATH GUARD
--  If the charge path crosses deep water, prevent the warrior from getting
--  stuck in swimming animation at the mid-point.
-- =============================================================================

--- Check whether the straight-line path between two points crosses water.
--  Samples 5 points and checks each for deep water.
local function PathCrossesWater(player, px, py, pz, tx, ty, tz)
    local SAMPLES = 5
    for i = 1, SAMPLES - 1 do
        local t = i / SAMPLES
        local sx = Lerp(px, tx, t)
        local sy = Lerp(py, ty, t)
        local sz = Lerp(pz, tz, t)
        if IsDeepWater(player, sx, sy, sz) then
            return true
        end
    end
    return false
end

--- If path crosses water, try to find an alternate route that goes around.
local function AvoidWaterPath(player, px, py, pz, tx, ty, tz)
    -- Try rotating the path 30 / -30 / 60 / -60 degrees
    local angles = { math.pi/6, -math.pi/6, math.pi/3, -math.pi/3 }
    for _, ang in ipairs(angles) do
        local len = Dist3D(px, py, pz, tx, ty, tz)
        local dx = tx - px
        local dy = ty - py
        local rdx, rdy = Rotate2D(dx, dy, ang)
        local nx = px + rdx * (len / math.sqrt(rdx*rdx + rdy*rdy + 0.0001))
        local ny = py + rdy * (len / math.sqrt(rdx*rdx + rdy*rdy + 0.0001))
        local nz = Lerp(pz, tz, 1.0)
        if not PathCrossesWater(player, px, py, pz, nx, ny, nz) then
            return nx, ny, nz, true
        end
    end
    return tx, ty, tz, false  -- Could not avoid, proceed anyway
end

