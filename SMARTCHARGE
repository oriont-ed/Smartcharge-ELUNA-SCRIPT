-- =============================================================================
--  §15  SPLINE PATH RECORDER
--  For the highest quality movement, we pre-compute a multi-point spline
--  and feed it to TrinityCore's MoveSplinePath.  This avoids the single
--  MoveTo() call and gives smoother pathing around obstacles.
-- =============================================================================

local SPLINE_POINTS = 5  -- Number of control points to feed

--- Generate a Catmull-Rom spline between start and end, bowing slightly
--  around any detected obstacle midpoint.
--  Uses a smooth, premium trigonometric sine wave peak for natural curvature.
local function ComputeSplinePoints(px, py, pz, tx, ty, tz, bowFactor)
    bowFactor = bowFactor or 0.0  -- 0 = straight, positive = bow outward

    local pts = {}
    for i = 0, SPLINE_POINTS - 1 do
        local t = i / (SPLINE_POINTS - 1)
        local x = Lerp(px, tx, t)
        local y = Lerp(py, ty, t)
        local z = Lerp(pz, tz, t)

        -- Add perpendicular bow at t=0.5 using high-fidelity sine wave
        if bowFactor ~= 0 then
            local midFactor = math.sin(t * math.pi)  -- smooth trigonometric sine arc (peaks at t=0.5)
            local perpX = -(ty - py)  -- perpendicular to forward direction
            local perpY =  (tx - px)
            local perpLen = math.sqrt(perpX*perpX + perpY*perpY)
            if perpLen > 0.001 then
                perpX = perpX / perpLen
                perpY = perpY / perpLen
                x = x + perpX * bowFactor * midFactor
                y = y + perpY * bowFactor * midFactor
            end
        end

        table.insert(pts, { x = x, y = y, z = z })
    end
    return pts
end

--- Attempt to issue a spline-path movement.
--  Returns true on success.
local function IssueSplineMovement(player, state, bowFactor)
    bowFactor = bowFactor or 0.0
    local pts = ComputeSplinePoints(
        state.srcX, state.srcY, state.srcZ,
        state.destX, state.destY, state.destZ,
        bowFactor)

    -- Try MoveSplinePath (TC3.3.5a specific Eluna extension)
    local ok = pcall(function()
        -- Build the point list in the format Eluna expects
        -- (varies by fork – some take a flat array, some take a table of tables)
        local flat = {}
        for _, p in ipairs(pts) do
            table.insert(flat, p.x)
            table.insert(flat, p.y)
            table.insert(flat, p.z)
        end
        player:MoveSplinePath(flat)
    end)
    return ok
end

