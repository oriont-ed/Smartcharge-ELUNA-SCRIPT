CreateLuaEvent(function()
    local now = os.time()
    for key, t in pairs(ChargeCooldowns) do
        if (now - t) > 120 then  -- Purge entries older than 2 min
            ChargeCooldowns[key] = nil
        end
    end
end, CD_CLEANUP_INTERVAL * 1000, 9999)  -- Bug 16: 0 = infinite in Eluna 3.x; use large finite count

