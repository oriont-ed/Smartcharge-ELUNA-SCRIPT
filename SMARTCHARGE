local ChargeCooldowns = {}  -- [guidStr] = timestamp (os.time())

local CHARGE_CD_SECONDS = {
    [100]   = 15,  -- Charge R1
    [6178]  = 15,  -- Charge R2
    [11578] = 15,  -- Charge R3
    [20252] = 30,  -- Intercept
    [3411]  = 30,  -- Intervene
}

--- Returns true if the player is on Lua-level cooldown for this spell.
local function IsOnLuaCooldown(player, spellId)
    local guid = tostring(player:GetGUIDLow())
    local key = guid .. "_" .. tostring(spellId)
    local lastCast = ChargeCooldowns[key]
    if not lastCast then return false end
    local cd = CHARGE_CD_SECONDS[spellId] or 15
    return (os.time() - lastCast) < cd
end

