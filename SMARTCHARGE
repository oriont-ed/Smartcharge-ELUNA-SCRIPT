local function AssertEq(a, b, msg)
    if a ~= b then
        error((msg or "assert") .. " expected=" .. tostring(b) ..
              " got=" .. tostring(a))
    end
end

local function AssertNear(a, b, tol, msg)
    tol = tol or 0.001
    if math.abs(a - b) > tol then
        error((msg or "near") .. " expected≈" .. tostring(b) ..
              " got=" .. tostring(a) .. " tol=" .. tostring(tol))
    end
end

local function AssertTrue(v, msg)
    if not v then error((msg or "assert_true") .. " was false/nil") end
end

local function AssertFalse(v, msg)
    if v then error((msg or "assert_false") .. " was true") end
end

