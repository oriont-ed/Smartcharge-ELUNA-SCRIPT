--  Bug 7 fix: the original code monkey-patched OnCommand twice (§38, §43)
--  using _prev chains.  A single authoritative handler is simpler, safer,
--  and avoids the fragility of chained closures.
-- =============================================================================

local function OnCommand(event, player, command)
    local cmd = command:lower()

    -- §23: debug toggle / status
    if cmd == "chargedebug on" then
        if player:GetGMRank() < 1 then return end
        DEBUG_ENABLED = true
        INFO(player, "SmartCharge debug ON.")
        return false
    end

    if cmd == "chargedebug off" then
        if player:GetGMRank() < 1 then return end
        DEBUG_ENABLED = false
        INFO(player, "SmartCharge debug OFF.")
        return false
    end

    if cmd == "chargestatus" then
        if player:GetGMRank() < 1 then return end
        local count = 0
        for guid, state in pairs(ChargeState) do
            if state.active then count = count + 1 end
        end
        INFO(player, "Active charges: " .. tostring(count))
        return false
    end

    -- §38: metrics dump
    if cmd == "chargemetrics" then
        if player:GetGMRank() < 1 then return end
        for k, v in pairs(ChargeMetrics) do
            INFO(player, k .. " = " .. tostring(v))
        end
        return false
    end

    -- §43: per-player state dump
    local sub = cmd:sub(1, 11)
    if sub == "chargestate" then
        if player:GetGMRank() < 1 then return end
        local target = player:GetSelection()
        if target then
            local state = StateGet(target)
            INFO(player, SerialiseState(state))
        else
            INFO(player, "Select a target first.")
        end
        return false
    end
end

