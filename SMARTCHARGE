local ChargeMetrics = {
    totalCharges      = 0,
    successfulLandings = 0,
    adjustedPaths     = 0,
    fallbackPaths     = 0,
    blockedCharges    = 0,
    voidAborts        = 0,
    timeoutAborts     = 0,
    avgTicks          = 0,
    tickSamples       = 0,
}

--- Record a charge outcome in the metrics table.
local function RecordMetric(key, extraTicks)
    ChargeMetrics[key] = (ChargeMetrics[key] or 0) + 1
    if key == "successfulLandings" and extraTicks then
        local n = ChargeMetrics.tickSamples
        ChargeMetrics.avgTicks =
            (ChargeMetrics.avgTicks * n + extraTicks) / (n + 1)
        ChargeMetrics.tickSamples = n + 1
    end
end

