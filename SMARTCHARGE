-- §14.1  Water Detection
-- TrinityCore's IsInWater() is exposed on units. For map points we must
-- infer water presence from the floor-Z vs liquid-Z difference.

local LIQUID_TYPE_NONE  = 0
local LIQUID_TYPE_WATER = 1
local LIQUID_TYPE_LAVA  = 2
local LIQUID_TYPE_SLIME = 3

--- Attempt to get liquid level at a coordinate.
--  Returns (liquidZ, liquidType, success).
--
--  Bug 10 fix: map:GetLiquidData(x, y, z) is not exposed in Eluna 3.x.
--  We fall back to player:IsInWater() for the player's current position,
--  and use floor-Z heuristics for arbitrary map points.
local function GetLiquidData(player, x, y, z)
    -- For the player's own location we can use the unit API.
    local px, py, pz = SafeGetLoc(player)
    if px then
        local dSq = DistSq2D(px, py, x, y)
        if dSq < 1.0 * 1.0 then
            -- Close enough to use the unit water check
            local ok, inWater = pcall(function() return player:IsInWater() end)
            if ok and inWater then
                return z, LIQUID_TYPE_WATER, true
            end
            return z, LIQUID_TYPE_NONE, true
        end
    end
    -- For arbitrary map points: compare query Z with floor Z.
    -- If the floor is significantly below the query point, water is plausible.
    local fz, floorOk = GetFloorZ(player, x, y, z)
    if floorOk and (z - fz) > WATER_DEPTH_SAFE then
        return fz, LIQUID_TYPE_WATER, true
    end
    return z, LIQUID_TYPE_NONE, false
end

--- Returns true if the destination appears to be deep water.
local function IsDeepWater(player, x, y, z)
    local lz, lt, ok = GetLiquidData(player, x, y, z)
    if not ok then return false end  -- Assume safe if API missing
    if lt == LIQUID_TYPE_WATER then
        local depth = lz - z
        return depth > WATER_DEPTH_SAFE
    end
    return false
end

--- Returns true if the destination is lava or slime (always unsafe).
local function IsLethalLiquid(player, x, y, z)
    local lz, lt, ok = GetLiquidData(player, x, y, z)
    if not ok then return false end
    return lt == LIQUID_TYPE_LAVA or lt == LIQUID_TYPE_SLIME
end

-- §14.2  Elevation Profile Analysis
-- When player Z and target Z differ significantly, we sample intermediate
-- points to detect whether the terrain forms an unnavigable cliff.

local ELEVATION_SAMPLE_COUNT = 8  -- Number of intermediate samples

--- Sample the elevation profile between two points.
--  Returns a table of {t, z, floorZ} entries and a boolean (hasCliff).
local function SampleElevationProfile(player, px, py, pz, tx, ty, tz)
    local samples = {}
    local hasCliff = false
    local prevFloorZ = nil

    for i = 0, ELEVATION_SAMPLE_COUNT do
        local t = i / ELEVATION_SAMPLE_COUNT
        local sx = Lerp(px, tx, t)
        local sy = Lerp(py, ty, t)
        local sz = Lerp(pz, tz, t)
        local fz, ok = GetFloorZ(player, sx, sy, sz)
        local entry = { t = t, sampleZ = sz, floorZ = ok and fz or sz }
        table.insert(samples, entry)

        -- Detect cliff: floor-Z drops by more than MAX_Z_FALL_DELTA between samples
        if prevFloorZ and ok then
            local drop = prevFloorZ - fz
            if drop > MAX_Z_FALL_DELTA then
                hasCliff = true
                DBG(player, string.format(
                    "Cliff detected at t=%.2f: floor drop %.1f yds", t, drop))
            end
        end
        if ok then prevFloorZ = fz end
    end

    return samples, hasCliff
end

--- Extended destination validation using elevation profile.
--  Wraps ValidateDestination with cliff detection.
local function ValidateDestinationDeep(player, px, py, pz, tx, ty, tz)
    -- Basic checks first
    local dx, dy, dz, basicSafe = ValidateDestination(player, px, py, pz, tx, ty, tz)
    if not basicSafe then return dx, dy, dz, false, "basic_fail" end

    -- Liquid checks
    if IsLethalLiquid(player, dx, dy, dz) then
        return dx, dy, dz, false, "lethal_liquid"
    end

    -- Deep water: warriors can charge into water but it's often a griefing spot
    -- Allow it but warn
    if IsDeepWater(player, dx, dy, dz) then
        DBG(player, "Charge destination is deep water.")
        -- Still allow – warrior can enter water
    end

    -- Elevation profile / cliff analysis
    local _, hasCliff = SampleElevationProfile(player, px, py, pz, tx, ty, tz)
    if hasCliff then
        return dx, dy, dz, false, "cliff"
    end

    return dx, dy, dz, true, "ok"
end

-- §14.3  Advanced Alternative Point Finder using deep validation

--- Like FindSafeLandingPoint but uses deep validation and scores candidates.
local function FindSafeLandingPointDeep(player, px, py, pz, tx, ty, tz)
    local candidates = GenerateAlternatives(player, px, py, pz, tx, ty, tz)
    local best = nil
    local bestScore = math.huge

    for _, c in ipairs(candidates) do
        local sx, sy, sz, safe, reason =
            ValidateDestinationDeep(player, px, py, pz, c.x, c.y, c.z)

        if safe then
            local hasLOS = CheckLOS(player, sx, sy, sz)
            if hasLOS then
                -- Score = distance from original target (prefer closer)
                local score = DistSq3D(sx, sy, sz, tx, ty, tz)
                if score < bestScore then
                    bestScore = score
                    best = { x = sx, y = sy, z = sz }
                end
            end
        else
            DBG(player, "Candidate rejected: " .. (reason or "?"))
        end
    end

    if best then
        return best.x, best.y, best.z, true
    end

    -- Ultimate fallback
    local ndx, ndy, _ = Normalise2D(tx - px, ty - py)
    return px + ndx * 2.0, py + ndy * 2.0, pz, false
end

--- Enhanced ResolveDestination using deep checks.
--  NOTE: This definition (§14) is intentionally NOT assigned to
--  ResolveDestination here.  The full navigation pipeline (§35) supersedes it
--  and is the only active assignment.  Kept as a callable helper for any
--  internal use that wants the simpler two-tier path.
local function ResolveDestinationEnhanced(player, px, py, pz, tx, ty, tz)
    -- Direct path with deep validation
    local dx, dy, dz, safe, reason =
        ValidateDestinationDeep(player, px, py, pz, tx, ty, tz)
    local los = safe and CheckLOS(player, dx, dy, dz)

    if safe and los then
        return dx, dy, dz, "direct"
    end

    DBG(player, "Direct path blocked (" .. (reason or "los") .. ") – seeking alternative.")

    -- Smart alternative search
    local ax, ay, az, found =
        FindSafeLandingPointDeep(player, px, py, pz, tx, ty, tz)
    if found then
        return ax, ay, az, "adjusted"
    end

    return ax, ay, az, "fallback"
end

