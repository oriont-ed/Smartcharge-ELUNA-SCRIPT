--- Safe speed exploit guard to prevent players from getting stuck in high-speed mode.
--  If the player is not actively charging, their running speed is clamped to normal.
local function SanitizePlayerSpeed(player)
    if not player or not player:IsInWorld() then return end
    if player:GetClass() ~= 1 then return end -- Only sanitize Warriors
    if player:IsMounted() then return end -- Never sanitize mounted players
    if not IsAlreadyCharging(player) then
        local ok, spd = pcall(function() return player:GetSpeed(SPEED_RUN) end)
        -- Normal run speed with buffs/mounts should never exceed 2.5 relative index (250%)
        if ok and spd and (spd > 2.5) then
            pcall(function() player:SetSpeed(SPEED_RUN, 1.0) end)
            pcall(function() player:RemoveAura(SPELL_BOOTS_FLAMES) end)
            DBG(player, "Exploit Speed Guard: Sanitized speed from " .. tostring(spd) .. " to 1.0")
        end
    end
end

--- Intercept PLAYER_EVENT_ON_SPELL_CAST (event ID 5).
-- NOTE: In Eluna 3.3.5a the third argument can be either a raw spellId integer
-- or a Spell object (userdata). We handle both polymorphically to ensure reliability.
local function OnSpellCast(event, player, spellOrId, skipCheck)
    local spellId
    if type(spellOrId) == "number" then
        spellId = spellOrId
    elseif type(spellOrId) == "userdata" then
        local ok, entry = pcall(function() return spellOrId:GetEntry() end)
        if ok and entry then
            spellId = entry
        else
            return
        end
    else
        return
    end

    if not CHARGE_SPELLS[spellId] then
        return  -- Not a charge-family spell; ignore
    end

    -- Exploit speed guard: sanitize player speed if they are not actively charging
    SanitizePlayerSpeed(player)

    -- We do NOT return true here – the default spell cast should still fire
    -- for animation, sound, and server-side cooldown tracking.
    -- We only override MOVEMENT and EFFECTS.
    InitiateCharge(player, spellId)
end

--- Clean up state when a player logs out or disconnects.
local function OnPlayerLogout(event, player)
    local state = StateGet(player)
    if state then
        AbortCharge(player, state, "logout")
        StateRemove(player)
    end
    -- Always force sanitize run speed on logout/login to prevent exploit carryover
    pcall(function() player:SetSpeed(SPEED_RUN, 1.0) end)
end

--- Clean up state on player death (charge is auto-cancelled by the server).
local function OnPlayerDeath(event, player, killer)
    local state = StateGet(player)
    if state then
        AbortCharge(player, state, "player died")
        StateRemove(player)
    end
end

--- Handle the case where a charge target dies mid-flight.
local function OnUnitDeath(event, unit, killer)
    -- We need to check if any charging player was targeting this unit.
    -- Iterate active states.  This is O(n) over active charges (usually ~0–2).
    local deadGuid = tostring(unit:GetGUIDLow())
    for guidStr, state in pairs(ChargeState) do
        if state.targetGuid == deadGuid and state.active then
            -- Target died – the charge can still land, but we skip the stun.
            -- Effects will be applied (rage only) when the arrival tick fires.
            DBG(nil, "Charge target " .. deadGuid .. " died mid-flight.")
            -- No abort needed; OnArrivalTick handles dead targets gracefully.
        end
    end
end

