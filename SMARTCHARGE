-- =============================================================================
--  §17  TERRAIN TYPE DETECTION HELPERS
--  WotLK has several terrain flags that affect movement legality.
-- =============================================================================

-- Terrain flags (matching TrinityCore's GridTerrainType enum subset)
local TERRAIN_NORMAL   = 0
local TERRAIN_WATER    = 1
local TERRAIN_MAGMA    = 2
local TERRAIN_SLIME    = 3

--- Attempt to read terrain type at a point.
--  Bug 20 fix: map:GetTerrainType() is not exposed in Eluna 3.x.
--  The pcall guard prevents crashes, but every call would silently fail.
--  We document this limitation and return TERRAIN_NORMAL as the safe default
--  (lava/slime is caught by the liquid checks instead).
local function GetTerrainType(player, x, y, z)
    -- map:GetTerrainType() is unavailable in standard Eluna 3.x builds.
    -- Dangerous terrain (lava/slime) is detected via GetLiquidData() liquid
    -- type checks.  This function is kept as a hook for custom Eluna forks
    -- that expose the API.
    local ok, tt = pcall(function()
        local map = player:GetMap()
        if not map then return TERRAIN_NORMAL end
        return map:GetTerrainType(x, y, z)
    end)
    if ok and tt then return tt end
    return TERRAIN_NORMAL
end

--- Returns true if the terrain at the destination is dangerous.
local function IsDangerousTerrain(player, x, y, z)
    local tt = GetTerrainType(player, x, y, z)
    return tt == TERRAIN_MAGMA or tt == TERRAIN_SLIME
end

-- =============================================================================
--  §18  FACING / ORIENTATION MANAGEMENT
--  After a charge the player should face the target.  Eluna's SetFacing()
--  takes a radian angle.  We compute this from the direction vector.
-- =============================================================================

--- Compute the facing angle from (fx,fy) toward (tx,ty) in radians.
local function ComputeFacing(fx, fy, tx, ty)
    return math.atan2(ty - fy, tx - fx)
end

--- Make the player face their target after landing (cosmetic but important).
local function FaceTarget(player, target)
    if not player or not player:IsInWorld() then return end
    if not target or not target:IsInWorld() then return end

    local px, py, _ = SafeGetLoc(player)
    local tx, ty, _ = SafeGetLoc(target)
    if not px or not tx then return end

    local angle = ComputeFacing(px, py, tx, ty)
    pcall(function() player:SetFacing(angle) end)
end

-- =============================================================================
--  §19  COMBAT ENGAGEMENT SYSTEM
--  A charge must trigger melee combat engagement correctly.
--  TrinityCore handles this internally when a spell is cast, but since we
--  are injecting movement, we verify that combat is entered.
-- =============================================================================

--- Ensure the player is in combat with the target after landing.
local function EnsureCombatEngaged(player, target)
    if not player or not player:IsInWorld() then return end
    if not target or not target:IsInWorld() then return end

    -- Bug 11 fix: player:IsInCombatWith(target) is not a valid Eluna 3.3.5a
    -- API.  Use player:IsInCombat() (unit-level flag) instead.
    local ok, inCombat = pcall(function()
        return player:IsInCombat()
    end)
    if ok and inCombat then return end  -- Already in combat; TC will handle targeting

    -- Attack the target to enter combat
    pcall(function() player:Attack(target, true) end)

    DBG(player, "Combat engagement forced.")
end

-- =============================================================================
--  §18+19+46 MERGED  APPLY LANDING EFFECTS
--  Bug 4 fix: the original code monkey-patched ApplyLandingEffects three
--  times (§18, §19, §46) building a fragile _orig chain.  If any intermediate
--  assignment was nil the entire chain broke silently.  All three concerns are
--  now inlined into one authoritative function.
-- =============================================================================

--- Apply all landing effects (stun, rage, safe-fall, facing, combat).
--  This is the single canonical implementation – no _orig chains.
ApplyLandingEffects = function(player, target, spellId)
    if not player or not player:IsInWorld() then return end

    -- §46 Safe-fall: if we dropped significantly, apply levitate to prevent
    -- fall damage.  Read Z values from state.
    local state = StateGet(player)
    if state and state.srcZ and state.destZ then
        local drop = state.srcZ - state.destZ
        if drop > FALL_DAMAGE_THRESHOLD then
            pcall(function() player:AddAura(FALL_SAFE_AURA, player) end)
            DBG(player, string.format("Safe-fall applied: drop=%.1f yards", drop))
        end
    end

    -- Ultra-Polish landing visuals: powerful metal/thunder impact sound & cosmetic ground shockwave!
    pcall(function()
        -- Play Sound ID 3117 (Heavy impact thunder crash)
        player:PlaySoundToPlayer(3117)
    end)
    pcall(function()
        -- Cast Spell ID 11963 (Harmless cosmetic Thunderclap ground shockwave)
        player:CastSpell(player, 11963, true)
    end)

    if not target or not target:IsInWorld() or not target:IsAlive() then
        -- Target died or disconnected mid-charge – still grant rage
        GrantRage(player, GetRageGrant(spellId))
        return
    end

    -- Stun the target
    local stunAura = GetStunAura(spellId)
    if stunAura then
        pcall(function()
            player:CastSpell(target, stunAura, true)
        end)
    end

    -- Grant rage to caster
    GrantRage(player, GetRageGrant(spellId))

    -- §18 Face the target perfectly (forces perfect client facing angle instantly)
    pcall(function() player:SetFacingToObject(target) end)
    FaceTarget(player, target)

    -- §19 Engage combat (Intervene is friendly; skip combat for it)
    if spellId ~= SPELL_INTERVENE then
        EnsureCombatEngaged(player, target)
    end

    DBG(player, "Landing effects applied. Spell=" .. tostring(spellId))
end

