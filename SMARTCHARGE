-- =============================================================================
--  §8  ARRIVAL DETECTION & POST-FLIGHT CLEANUP
--  We poll position every TICK_ARRIVAL_CHECK_MS milliseconds.
--  Hard cap at MAX_FLIGHT_TICKS to prevent runaway events.
-- =============================================================================

--- Immediately cancel all events and restore the player to normal state.
--  Safe to call multiple times (idempotent).
local function AbortCharge(player, state, reason)
    if not state or not state.active then return end
    state.active = false

    RestoreSpeeds(player, state)
    -- Cancel only our specific polling event via RemoveEventById.
    -- We deliberately do NOT call player:RemoveEvents() here because that
    -- removes ALL player-bound events (including ones from unrelated scripts)
    -- and calling it from within an event callback causes undefined behaviour
    -- / infinite loops in Eluna 3.x.
    if player and player:IsInWorld() and state.eventHandle then
        pcall(function() player:RemoveEventById(state.eventHandle) end)
        state.eventHandle = nil
    end

    -- Bug 15 fix: cancel any in-flight speed-ramp events
    if player and player:IsInWorld() and state.rampHandles then
        for _, h in ipairs(state.rampHandles) do
            pcall(function() player:RemoveEventById(h) end)
        end
        state.rampHandles = nil
    end

    -- Cancel the post-land effect event if it was registered but not yet fired
    if player and player:IsInWorld() and state.landHandle then
        pcall(function() player:RemoveEventById(state.landHandle) end)
        state.landHandle = nil
    end

    DBG(player, "Charge aborted: " .. (reason or "unknown"))
end

--- Called once per TICK_ARRIVAL_CHECK_MS while the charge is in-flight.
--  Determines if the player has reached the destination or if we must abort.
local function OnArrivalTick(eventId, delay, calls, player, state, target)
    -- Guard: player or state gone
    if not player or not player:IsInWorld() then return end
    if not state or not state.active then return end

    state.ticks = state.ticks + 1

    -- Hard cap
    if state.ticks > MAX_FLIGHT_TICKS then
        WARN(player, "Charge timeout – forcing landing.")
        AbortCharge(player, state, "timeout")
        -- Apply effects at wherever the player ended up
        ApplyLandingEffects(player, target, state.spellId)
        return
    end

    -- Check void / underground during flight (extra safety)
    local cx, cy, cz = SafeGetLoc(player)
    if not cx then
        AbortCharge(player, state, "player location invalid mid-flight")
        return
    end
    if cz < VOID_THRESHOLD_Z then
        -- Player fell into the void – teleport back to source
        ERR(player, "Detected void fall during charge! Recovering.")
        pcall(function()
            player:Teleport(player:GetMapId(), state.srcX or cx,
                            state.srcY or cy, state.srcZ or cz,
                            player:GetO())
        end)
        AbortCharge(player, state, "void fall")
        return
    end
    -- Exploit Water Check mid-flight: Force-land immediately if the player touches water
    local okWater, inWater = pcall(function() return player:IsInWater() end)
    if okWater and inWater then
        DBG(player, "Player entered water mid-charge – landing forced.")
        state.active = false
        RestoreSpeeds(player, state)
        pcall(function() player:RemoveEventById(eventId) end)
        state.eventHandle = nil
        ApplyLandingEffects(player, target, state.spellId)
        return
    end

    -- Proximity check (2-D to avoid Z noise from spline)
    local dSq = DistSq2D(cx, cy, state.destX, state.destY)
    if dSq <= CHARGE_LAND_RADIUS_SQ then
        -- Arrived!
        state.active = false
        RestoreSpeeds(player, state)
        -- Cancel the outer polling event (our own eventId).
        -- We do NOT call RemoveEvents() to avoid nuking unrelated events.
        pcall(function() player:RemoveEventById(eventId) end)
        state.eventHandle = nil

        -- Delay effect application by one short tick so TC processes move first.
        -- Bug 3 fix: store this handle so AbortCharge can cancel it if the
        -- player disconnects between now and POST_LAND_DELAY_MS.
        local landHandle
        landHandle = player:RegisterEvent(function(eid, d, c, pl)
            ApplyLandingEffects(pl, target, state.spellId)
            pcall(function() pl:RemoveEventById(eid) end)
        end, POST_LAND_DELAY_MS, 1)
        state.landHandle = landHandle

        DBG(player, "Charge landed at " .. FmtXYZ(cx, cy, cz) ..
                    " after " .. tostring(state.ticks) .. " ticks.")
    end
    -- else: still in flight, next tick will check again
end

-- =============================================================================
--  §9  MOVEMENT ISSUANCE
--  We wrap player:MoveTo() with multiple safety layers.
-- =============================================================================

--- Issue the actual movement order to TrinityCore via Eluna.
--  Returns true if movement was issued successfully.
local function IssueMovement(player, state)
    local dx, dy, dz = state.destX, state.destY, state.destZ

    -- Attempt 1: MoveTo with pathfinding (MMap routing around obstacles)
    local ok1 = pcall(function()
        -- MoveTo(type, x, y, z, generatePath)
        -- type 0 = Point movement (not waypoint following)
        player:MoveTo(0, dx, dy, dz, true)
    end)
    if ok1 then
        DBG(player, "Movement issued via MoveTo(pathfinding=true)")
        return true
    end

    -- Attempt 2: MoveTo without pathfinding (straight-line spline)
    local ok2 = pcall(function()
        player:MoveTo(0, dx, dy, dz, false)
    end)
    if ok2 then
        DBG(player, "Movement issued via MoveTo(pathfinding=false) [fallback]")
        state.usedFallback = true
        return true
    end

    -- Attempt 3: MovePoint – alternate Eluna API name on some forks
    local ok3 = pcall(function()
        player:MovePoint(1, dx, dy, dz)
    end)
    if ok3 then
        DBG(player, "Movement issued via MovePoint() [fallback2]")
        state.usedFallback = true
        return true
    end

    ERR(player, "All movement APIs failed. Check your Eluna build.")
    return false
end

-- =============================================================================
--  §10  ANTI-EXPLOIT LAYER
--  Prevents:
--   a) Casting charge while already charging (duplicate events).
--   b) Using speed during cooldown via other movement hacks.
--   c) Map-edge charging (destinations near zone boundaries).
-- =============================================================================

--- Check if player already has an active charge in our state table.
local function IsAlreadyCharging(player)
    local state = StateGet(player)
    return state ~= nil and state.active == true
end

--- Detect if destination is suspiciously close to a map edge.
--  A rough heuristic – real MMaps will catch most of these, but we add
--  an extra layer for coordinates known to be problematic.
local function IsSuspiciousMapEdge(x, y)
    -- TrinityCore maps use a coordinate system centered on (0,0).
    -- The maximum valid range is roughly ±17066.  Flag anything beyond ±16500.
    local EDGE_THRESHOLD = 16500
    return math.abs(x) > EDGE_THRESHOLD or math.abs(y) > EDGE_THRESHOLD
end

