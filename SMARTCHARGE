-- =============================================================================
--  §28  NAVIGATION RENDERER  –  Server-side path quality analyser
--  This section implements a full navigation analysis pipeline that
--  categorises every charge attempt into a quality tier and selects the
--  optimal movement strategy for each tier.
-- =============================================================================

-- Quality tiers
local NAV_TIER_PERFECT   = 1  -- Direct LoS, flat terrain, no liquids
local NAV_TIER_GOOD      = 2  -- Minor obstacle, adjusted path found
local NAV_TIER_MODERATE  = 3  -- Significant re-route, spline required
local NAV_TIER_POOR      = 4  -- Only fallback available, short hop
local NAV_TIER_BLOCKED   = 5  -- Charge is unsafe / must be cancelled

local NAV_TIER_NAMES = {
    [NAV_TIER_PERFECT]  = "PERFECT",
    [NAV_TIER_GOOD]     = "GOOD",
    [NAV_TIER_MODERATE] = "MODERATE",
    [NAV_TIER_POOR]     = "POOR",
    [NAV_TIER_BLOCKED]  = "BLOCKED",
}

--- A NavReport contains all computed data about a single charge navigation
--- decision.  It is created by AnalyseNavigation() and consumed by
--- SelectMovementStrategy().
local function NewNavReport(px, py, pz, tx, ty, tz)
    return {
        srcX = px, srcY = py, srcZ = pz,
        dstX = tx, dstY = ty, dstZ = tz,
        -- Results
        tier           = NAV_TIER_BLOCKED,
        finalDstX      = tx,
        finalDstY      = ty,
        finalDstZ      = tz,
        directLoS      = false,
        hasCliff       = false,
        hasLiquid      = false,
        hasLethal      = false,
        isVoid         = false,
        isMapEdge      = false,
        bowFactor      = 0.0,
        adjustAngles   = {},
        qualityStr     = "BLOCKED",
        errorReason    = nil,
        -- Perf stats
        candidatesTried = 0,
        timeUsed_ms    = 0,
    }
end

--- Main navigation analyser – fills a NavReport with all computed data.
local function AnalyseNavigation(player, report)
    local t0 = os.clock()

    local px, py, pz = report.srcX, report.srcY, report.srcZ
    local tx, ty, tz = report.dstX, report.dstY, report.dstZ

    -- 1. Void / map-edge quick rejects
    if IsVoidPoint(tx, ty, tz) then
        report.isVoid = true
        report.tier = NAV_TIER_BLOCKED
        report.errorReason = "void_destination"
        return
    end
    if IsSuspiciousMapEdge(tx, ty) then
        report.isMapEdge = true
        report.tier = NAV_TIER_BLOCKED
        report.errorReason = "map_edge"
        return
    end

    -- 2. Lethal terrain
    if IsDangerousTerrain(player, tx, ty, tz) then
        report.hasLethal = true
        report.tier = NAV_TIER_BLOCKED
        report.errorReason = "lethal_terrain"
        return
    end

    -- 3. Cliff / elevation profile
    local _, hasCliff = SampleElevationProfile(player, px, py, pz, tx, ty, tz)
    report.hasCliff = hasCliff

    -- 4. Direct LoS
    report.directLoS = CheckLOS(player, tx, ty, tz)

    -- 5. Deep water at destination
    report.hasLiquid = IsDeepWater(player, tx, ty, tz)

    -- 6. Basic destination validation
    local dx, dy, dz, basicSafe = ValidateDestination(player, px, py, pz, tx, ty, tz)

    -- 7. Determine tier
    if basicSafe and report.directLoS and not hasCliff and not report.hasLiquid then
        report.tier = NAV_TIER_PERFECT
        report.finalDstX, report.finalDstY, report.finalDstZ = dx, dy, dz

    elseif basicSafe and not hasCliff then
        -- Needs LoS adjustment or liquid avoidance but still routable
        report.tier = NAV_TIER_GOOD
        report.finalDstX, report.finalDstY, report.finalDstZ = dx, dy, dz
        report.bowFactor = 1.5  -- Slight bow to arc around the obstacle

    elseif hasCliff then
        -- Try to find an alternative around the cliff
        local ax, ay, az, found =
            FindSafeLandingPointDeep(player, px, py, pz, tx, ty, tz)
        if found then
            report.tier = NAV_TIER_MODERATE
            report.finalDstX, report.finalDstY, report.finalDstZ = ax, ay, az
            report.bowFactor = 3.0
        else
            report.tier = NAV_TIER_POOR
            report.finalDstX, report.finalDstY, report.finalDstZ = ax, ay, az
        end

    else
        -- Destination not validatable but not explicitly blocked
        local ax, ay, az, found =
            FindSafeLandingPointDeep(player, px, py, pz, tx, ty, tz)
        if found then
            report.tier = NAV_TIER_GOOD
            report.finalDstX, report.finalDstY, report.finalDstZ = ax, ay, az
        else
            report.tier = NAV_TIER_POOR
            report.finalDstX, report.finalDstY, report.finalDstZ = ax, ay, az
        end
    end

    report.qualityStr = NAV_TIER_NAMES[report.tier] or "UNKNOWN"
    report.timeUsed_ms = math.floor((os.clock() - t0) * 1000)

    DBG(player, string.format(
        "NavReport tier=%s loS=%s cliff=%s bow=%.1f time=%dms",
        report.qualityStr,
        tostring(report.directLoS),
        tostring(report.hasCliff),
        report.bowFactor,
        report.timeUsed_ms))
end

--- Select movement strategy based on nav tier.
--  Returns a strategy table { moveFn, speedMult, description }.
local function SelectMovementStrategy(report)
    local tier = report.tier

    if tier == NAV_TIER_PERFECT then
        return {
            description = "Direct MMap path",
            useSpline   = false,
            usePathfind = true,
            bowFactor   = 0.0,
            speedMult   = 1.0,
        }
    elseif tier == NAV_TIER_GOOD then
        return {
            description = "MMap path",
            useSpline   = false,
            usePathfind = true,
            bowFactor   = 0.0,
            speedMult   = 1.0,
        }
    elseif tier == NAV_TIER_MODERATE then
        return {
            description = "Re-routed MMap path",
            useSpline   = false,
            usePathfind = true,
            bowFactor   = 0.0,
            speedMult   = 1.0,
        }
    elseif tier == NAV_TIER_POOR then
        return {
            description = "Short fallback MMap hop",
            useSpline   = false,
            usePathfind = true,
            bowFactor   = 0.0,
            speedMult   = 1.0,
        }
    else  -- BLOCKED
        return nil
    end
end

--- Execute a movement strategy on a player.
--  Bug 17 fix: ExecuteStrategy must NOT call the patched IssueMovement
--  (which retries spline first), because it already handles spline itself.
--  It calls the original pre-spline IssueMovement directly via _origIssueMovement.
local function ExecuteStrategy(player, state, strategy)
    if not strategy then return false end

    -- Apply speed
    local baseSpeed = (state.spellId == SPELL_INTERCEPT)
        and CHARGE_RUN_SPEED_INTERCEPT
        or  CHARGE_RUN_SPEED
    SafeSetSpeed(player, SPEED_RUN, baseSpeed * (strategy.speedMult or 1.0))

    -- Issue movement
    if strategy.useSpline and strategy.bowFactor ~= 0 then
        local ok = IssueSplineMovement(player, state, strategy.bowFactor)
        if ok then
            DBG(player, "Strategy: " .. strategy.description .. " [spline]")
            return true
        end
    end

    -- Fallback to MoveTo directly (bypass the patched IssueMovement to avoid
    -- a second spline attempt)
    local ok = pcall(function()
        player:MoveTo(0, state.destX, state.destY, state.destZ,
                      strategy.usePathfind)
    end)
    if ok then
        DBG(player, "Strategy: " .. strategy.description .. " [MoveTo]")
        return true
    end

    return false
end

-- =============================================================================
--  §29  UNIT COMBAT TRACKING
--  Tracks whether charge targets are still in combat and adjusts behaviour.
--  Primarily used to avoid wasting a charge on a target that's evading.
-- =============================================================================

local CombatTracker = {}  -- [guidStr] = { inCombat, lastUpdate }

local COMBAT_CACHE_TTL = 3  -- seconds; refresh after this

--- Update the combat status of a unit in the cache.
local function UpdateCombatCache(unit)
    if not unit or not unit:IsInWorld() then return end
    local guid = tostring(unit:GetGUIDLow())
    local ok, inCombat = pcall(function() return unit:IsInCombat() end)
    CombatTracker[guid] = {
        inCombat   = ok and inCombat or false,
        lastUpdate = os.time(),
    }
end

--- Get cached (or freshly queried) combat state of a unit.
local function IsTargetInCombat(unit)
    if not unit or not unit:IsInWorld() then return false end
    local guid = tostring(unit:GetGUIDLow())
    local cached = CombatTracker[guid]
    if cached and (os.time() - cached.lastUpdate) < COMBAT_CACHE_TTL then
        return cached.inCombat
    end
    UpdateCombatCache(unit)
    return CombatTracker[guid] and CombatTracker[guid].inCombat or false
end

-- Periodic cache cleanup
CreateLuaEvent(function()
    local now = os.time()
    for guid, data in pairs(CombatTracker) do
        if (now - data.lastUpdate) > 30 then
            CombatTracker[guid] = nil
        end
    end
end, 30000, 9999)  -- Bug 16: 0 = infinite in Eluna 3.x

-- =============================================================================
--  §30  TERRAIN MESH SAMPLER
--  Samples the terrain in a grid around the destination and picks the
--  highest-quality landing cell.  Used as a last resort when all other
--  methods produce a poor result.
-- =============================================================================

local MESH_RADIUS   = 4.0   -- Sample grid half-size in yards
local MESH_STEP     = 1.0   -- Step between sample points

--- Sample a 2-D grid of floor heights around a centre point.
--  Returns a table of { x, y, z, floorZ, safe } records.
local function SampleTerrainMesh(player, cx, cy, cz)
    local cells = {}
    local r = MESH_RADIUS
    local step = MESH_STEP
    local count = 0

    local y = cy - r
    while y <= cy + r do
        local x = cx - r
        while x <= cx + r do
            local fz, ok = GetFloorZ(player, x, y, cz + r)
            local safe = ok and not IsVoidPoint(x, y, fz)
                             and not IsDangerousTerrain(player, x, y, fz)
            if safe then
                local lz, lt, lok = GetLiquidData(player, x, y, fz)
                if lok and (lt == LIQUID_TYPE_LAVA or lt == LIQUID_TYPE_SLIME) then
                    safe = false
                end
            end
            table.insert(cells, {
                x     = x,
                y     = y,
                z     = ok and (fz + MIN_Z_ABOVE_GROUND) or cz,
                floorZ = ok and fz or cz,
                safe  = safe,
            })
            count = count + 1
            x = x + step
        end
        y = y + step
    end
    DBG(player, "Terrain mesh sampled: " .. count .. " cells around " ..
                FmtXYZ(cx, cy, cz))
    return cells
end

--- Find the best landing cell in the mesh nearest to a target point.
local function BestMeshCell(player, cells, tx, ty)
    local best = nil
    local bestScore = math.huge

    for _, cell in ipairs(cells) do
        if cell.safe then
            local hasLoS = CheckLOS(player, cell.x, cell.y, cell.z)
            if hasLoS then
                local score = DistSq2D(cell.x, cell.y, tx, ty)
                if score < bestScore then
                    bestScore = score
                    best = cell
                end
            end
        end
    end
    return best
end

--- Entry point for terrain mesh landing-point search.
--  Returns (x, y, z, found).
local function FindLandingViaMesh(player, px, py, pz, tx, ty, tz)
    local cells = SampleTerrainMesh(player, tx, ty, tz)
    local best  = BestMeshCell(player, cells, tx, ty)
    if best then
        -- Validate the chosen cell fully
        local dx, dy, dz, safe =
            ValidateDestination(player, px, py, pz, best.x, best.y, best.z)
        if safe then
            return dx, dy, dz, true
        end
    end
    return tx, ty, tz, false
end

