-- =============================================================================
--  §42  GROUND TRUTH VALIDATION
--  Periodically check that all values in CHARGE_EFFECTS agree with the
--  standalone effect functions.  Runs at startup only.
-- =============================================================================

local function ValidateEffectConsistency()
    local ok = true
    for spellId, data in pairs(CHARGE_EFFECTS) do
        local rage = GetRageGrant(spellId)
        if rage ~= data.rage then
            print(string.format(
                "[SmartCharge] WARNING: rage mismatch for spell %d: "..
                "table=%d function=%d", spellId, data.rage, rage))
            ok = false
        end
        local stun = GetStunAura(spellId)
        if stun ~= data.stun then
            print(string.format(
                "[SmartCharge] WARNING: stun mismatch for spell %d: "..
                "table=%s function=%s", spellId,
                tostring(data.stun), tostring(stun)))
            ok = false
        end
    end
    if ok then
        print("[SmartCharge] Effect table consistency: OK")
    end
end

ValidateEffectConsistency()

