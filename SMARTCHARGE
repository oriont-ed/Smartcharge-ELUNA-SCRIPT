-- =============================================================================
--  §34  ARENA-SPECIFIC SAFETY LAYER
--  Arenas have known geometry pain points (pillars, platform edges).
--  We add arena-pillar-aware LoS checks.
-- =============================================================================

-- Arena map IDs in WotLK
local ARENA_MAP_IDS = {
    [559] = true, -- Nagrand Arena
    [562] = true, -- Blade's Edge Arena
    [572] = true, -- Ruins of Lordaeron
    [617] = true, -- Dalaran Arena
    [618] = true, -- Ring of Valor
}

--- Returns true if the player is in an arena.
local function IsInArena(player)
    local ok, mapId = pcall(function() return player:GetMapId() end)
    if not ok then return false end
    return ARENA_MAP_IDS[mapId] == true
end

--- In arenas, we enforce stricter LoS requirements and shorter max range.
local function ApplyArenaConstraints(player, report)
    if not IsInArena(player) then return end

    -- Force LoS requirement
    if not report.directLoS then
        -- Try to find a LoS-clear alternative within 18 yards
        local px, py, pz = report.srcX, report.srcY, report.srcZ
        local tx, ty, tz = report.dstX, report.dstY, report.dstZ
        local ax, ay, az, found =
            FindSafeLandingPointDeep(player, px, py, pz, tx, ty, tz)
        if found then
            report.finalDstX = ax
            report.finalDstY = ay
            report.finalDstZ = az
            report.tier = NAV_TIER_GOOD
        else
            report.tier = NAV_TIER_BLOCKED
            report.errorReason = "arena_los_blocked"
        end
    end

    -- Clamp range to 22 yards in arenas
    local d2 = DistSq2D(report.srcX, report.srcY, report.finalDstX, report.finalDstY)
    if d2 > 22 * 22 then
        local ndx, ndy, _ = Normalise2D(
            report.finalDstX - report.srcX,
            report.finalDstY - report.srcY)
        report.finalDstX = report.srcX + ndx * 22
        report.finalDstY = report.srcY + ndy * 22
        DBG(player, "Arena range clamped to 22 yards.")
    end
end

-- =============================================================================
--  §35  FULL INTEGRATED NAVIGATION PIPELINE
--  Brings together §28 (NavReport), §30 (terrain mesh), §34 (arena safety).
-- =============================================================================

--- The master navigation function used by InitiateCharge (replaces
--- ResolveDestinationEnhanced with the full pipeline).
local function FullNavigationPipeline(player, px, py, pz, tx, ty, tz)
    -- Build report
    local report = NewNavReport(px, py, pz, tx, ty, tz)

    -- Analyse
    AnalyseNavigation(player, report)

    -- Arena constraint layer
    ApplyArenaConstraints(player, report)

    -- If blocked, attempt terrain mesh as last resort
    if report.tier == NAV_TIER_BLOCKED then
        local mx, my, mz, mfound =
            FindLandingViaMesh(player, px, py, pz, tx, ty, tz)
        if mfound then
            report.tier = NAV_TIER_POOR
            report.finalDstX = mx
            report.finalDstY = my
            report.finalDstZ = mz
            report.qualityStr = "POOR(mesh)"
            report.errorReason = nil
        end
    end

    -- If still blocked, return nil to abort
    if report.tier == NAV_TIER_BLOCKED then
        return nil, nil, nil, nil, report
    end

    -- Map tier to quality string for feedback
    local qualityStr = (report.tier == NAV_TIER_PERFECT) and "direct"
                    or (report.tier == NAV_TIER_GOOD)    and "adjusted"
                    or "fallback"

    return report.finalDstX, report.finalDstY, report.finalDstZ,
           qualityStr, report
end

-- Override the module-level ResolveDestination with the full pipeline
ResolveDestination = function(player, px, py, pz, tx, ty, tz)
    local dx, dy, dz, quality, report =
        FullNavigationPipeline(player, px, py, pz, tx, ty, tz)
    if not dx then
        -- Navigation completely blocked
        return px, py, pz, "fallback"
    end
    return dx, dy, dz, quality
end

-- =============================================================================
--  §36  ENHANCED INITIATECHARGE (final version – uses full pipeline)
-- =============================================================================

InitiateCharge = function(player, spellId)
    -- Exploit speed guard: sanitize player speed if they are not actively charging
    SanitizePlayerSpeed(player)

    -- Ultra Mobility: Immediately clear all root/snare slowing effects upon charge initiation!
    pcall(function() player:RemoveAurasByMechanic(11) end) -- MECHANIC_SNARE (movement slow)
    pcall(function() player:RemoveAurasByMechanic(12) end) -- MECHANIC_ROOT (movement root)

    if IsAlreadyCharging(player) then return end
    if IsOnLuaCooldown(player, spellId) then return end

    local px, py, pz = SafeGetLoc(player)
    if not px then return end

    -- Source underground guard
    local srcFloor, srcOk = GetFloorZ(player, px, py, pz)
    if srcOk and (pz - srcFloor) < -2.0 then
        WARN(player, "Cannot charge while underground.")
        return
    end

    -- Bug 14 fix: block charge while jumping / flying
    local canCharge, moveReason = CanChargeByMoveFlags(player)
    if not canCharge then
        WARN(player, "Cannot charge while " .. (moveReason or "airborne") .. ".")
        return
    end

    local target = player:GetSelection()
    local valid, errMsg = ValidateTarget(player, target, spellId)
    if not valid then return end

    local tx, ty, tz = SafeGetLoc(target)
    if not tx then return end

    -- Zone modifiers
    local zoneMod = GetZoneModifiers(player)
    local effectiveMax = CHARGE_RANGE_MAX
    if zoneMod then
        effectiveMax = effectiveMax * (zoneMod.rangeScale or 1.0)
    end
    if DistSq2D(px, py, tx, ty) > effectiveMax * effectiveMax then
        WARN(player, "Target out of range for this zone.")
        return
    end

    -- Full navigation pipeline
    local destX, destY, destZ, quality, report =
        FullNavigationPipeline(player, px, py, pz, tx, ty, tz)

    if not destX then
        WARN(player, "Charge path completely blocked.")
        return
    end

    -- Select movement strategy
    local strategy = report and SelectMovementStrategy(report)

    -- Feedback
    SendChargeFeedback(player, quality)

    -- State
    local state = StateInit(player)
    state.active       = true
    state.spellId      = spellId
    state.targetGuid   = tostring(target:GetGUIDLow())
    state.destX        = destX
    state.destY        = destY
    state.destZ        = destZ
    state.srcX         = px
    state.srcY         = py
    state.srcZ         = pz
    state.ticks        = 0
    state.usedFallback = (quality == "fallback")
    state.navReport    = report

    -- Cache speeds
    CacheSpeeds(player, state)

    -- Apply speed ramp (Bug 15 fix: pass state so handles are stored for cancel)
    local targetSpeed = (spellId == SPELL_INTERCEPT)
        and CHARGE_RUN_SPEED_INTERCEPT or CHARGE_RUN_SPEED
    if strategy then
        targetSpeed = targetSpeed * (strategy.speedMult or 1.0)
    end
    ApplySpeedRamp(player, targetSpeed, state)

    -- Issue movement via strategy
    local moved = false
    if strategy then
        moved = ExecuteStrategy(player, state, strategy)
    end
    if not moved then
        moved = IssueMovement(player, state)
    end

    if not moved then
        AbortCharge(player, state, "no movement API")
        StateRemove(player)
        return
    end

    RecordChargeCast(player, spellId)

    -- Apply boots flame visual during charge
    pcall(function() player:CastSpell(player, SPELL_BOOTS_FLAMES, true) end)

    local capturedTarget = target
    local capturedState  = state

    -- Bug 2 fix: store the polling event handle in state so AbortCharge can
    -- cancel it precisely without calling RemoveEvents().
    local pollHandle
    pollHandle = player:RegisterEvent(function(eventId, delay, calls, pl)
        if not capturedState or not capturedState.active then
            pcall(function() pl:RemoveEventById(eventId) end)
            capturedState.eventHandle = nil
            return
        end
        OnArrivalTick(eventId, delay, calls, pl, capturedState, capturedTarget)
        if not capturedState.active then
            pcall(function() pl:RemoveEventById(eventId) end)
            capturedState.eventHandle = nil
            CorrectLandingPosition(pl, capturedState.destX,
                                       capturedState.destY,
                                       capturedState.destZ)
            StateRemove(pl)
        end
    end, TICK_ARRIVAL_CHECK_MS, MAX_FLIGHT_TICKS + 10)
    state.eventHandle = pollHandle
end

