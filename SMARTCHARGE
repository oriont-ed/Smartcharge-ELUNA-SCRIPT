-- =============================================================================
--  §1  UTILITY / HELPER LAYER
-- =============================================================================

--- Clamp a numeric value between lo and hi.
local function Clamp(v, lo, hi)
    if v < lo then return lo end
    if v > hi then return hi end
    return v
end

--- Squared distance between two XYZ triples (avoids sqrt cost).
local function DistSq3D(x1, y1, z1, x2, y2, z2)
    local dx = x2 - x1
    local dy = y2 - y1
    local dz = z2 - z1
    return dx*dx + dy*dy + dz*dz
end

--- Squared 2-D distance (ignores Z – used for horizontal range checks).
local function DistSq2D(x1, y1, x2, y2)
    local dx = x2 - x1
    local dy = y2 - y1
    return dx*dx + dy*dy
end

--- Euclidean 3-D distance.
local function Dist3D(x1, y1, z1, x2, y2, z2)
    return math.sqrt(DistSq3D(x1, y1, z1, x2, y2, z2))
end

--- Linear interpolation.
local function Lerp(a, b, t)
    return a + (b - a) * t
end

--- Normalise a 2-D vector; returns (nx, ny, length).
local function Normalise2D(dx, dy)
    local len = math.sqrt(dx*dx + dy*dy)
    if len < 0.0001 then return 0, 0, 0 end
    return dx/len, dy/len, len
end

--- Rotate a 2-D point around the origin by angle (radians).
local function Rotate2D(x, y, angle)
    local c = math.cos(angle)
    local s = math.sin(angle)
    return c*x - s*y, s*x + c*y
end

--- Send a message to a player with colour prefix.
local function Msg(player, prefix, text)
    if player and player:IsInWorld() then
        player:SendBroadcastMessage(prefix .. text)
    end
end

local function DBG(player, text)
    if DEBUG_ENABLED then Msg(player, DEBUG_PREFIX, text) end
end

local function INFO(player, text)
    Msg(player, INFO_PREFIX, text)
end

local function WARN(player, text)
    Msg(player, WARN_PREFIX, text)
end

local function ERR(player, text)
    Msg(player, ERR_PREFIX, text)
end

--- Safe GetLocation wrapper – returns nil if the unit is invalid.
local function SafeGetLoc(unit)
    if not unit or not unit:IsInWorld() then return nil end
    local x, y, z = unit:GetLocation()
    -- Sanity: reject void coordinates
    if z < VOID_THRESHOLD_Z then return nil end
    return x, y, z
end

--- Build a human-readable "(x, y, z)" string for debug output.
local function FmtXYZ(x, y, z)
    return string.format("(%.2f, %.2f, %.2f)", x, y, z)
end

-- =============================================================================
--  §2  PLAYER STATE REGISTRY
--  Each charging warrior gets an entry keyed by their GUID (uint64 as string).
--  This prevents any cross-player state pollution and lets us track clean-up.
-- =============================================================================

local ChargeState = {} -- [guidStr] = state table

--- Create or reset the state entry for a player.
local function StateInit(player)
    local guid = tostring(player:GetGUIDLow())
    ChargeState[guid] = {
        guid          = guid,
        active        = false,       -- True while a charge is in-flight
        spellId       = 0,
        targetGuid    = "",          -- Target's GUID string
        -- Cached speeds to restore after charge
        prevSpeeds    = {},          -- [speedType] = speedValue
        -- Destination (clamped / validated)
        destX         = 0,
        destY         = 0,
        destZ         = 0,
        -- Tick counter for the arrival-poll loop
        ticks         = 0,
        eventHandle   = nil,         -- The RegisterEvent handle (for RemoveEventById if available)
        cleanupHandle = nil,
        -- Diagnostics
        pathAttempts  = 0,
        usedFallback  = false,
    }
    return ChargeState[guid]
end

--- Retrieve existing state or nil.
local function StateGet(player)
    local guid = tostring(player:GetGUIDLow())
    return ChargeState[guid]
end

--- Delete state entry – call once charge is fully resolved.
local function StateRemove(player)
    local guid = tostring(player:GetGUIDLow())
    ChargeState[guid] = nil
end

-- =============================================================================
--  §3  SPEED MANAGEMENT
--  TrinityCore/Eluna stores several speed types.  We must save and restore
--  ALL of them, because calling SetSpeed on RUN while swim-speed is custom will
--  silently reset swim-speed to base in some build revisions.
-- =============================================================================

local SPEED_TYPES = { SPEED_WALK, SPEED_RUN, SPEED_RUNBACK, SPEED_SWIM, SPEED_SWIMBACK }

--- Cache the player's current speeds into the state table.
local function CacheSpeeds(player, state)
    for _, stype in ipairs(SPEED_TYPES) do
        -- GetSpeed(speedType) is the Eluna API
        local ok, spd = pcall(function() return player:GetSpeed(stype) end)
        state.prevSpeeds[stype] = ok and spd or 1.0
    end
end

--- Apply a single speed type with error protection.
local function SafeSetSpeed(player, stype, value)
    if not player or not player:IsInWorld() then return end
    pcall(function() player:SetSpeed(stype, value) end)
end

--- Restore all cached speeds.
local function RestoreSpeeds(player, state)
    if not player or not player:IsInWorld() then return end
    for _, stype in ipairs(SPEED_TYPES) do
        local prev = state.prevSpeeds[stype] or 1.0
        -- Speed Exploit Guard: Clamp run speed to normal if the cached value was corrupted
        if stype == SPEED_RUN and (prev > 2.5) then
            prev = 1.0
        end
        -- Clamp swim speed to normal if the cached value was corrupted
        if (stype == SPEED_SWIM or stype == SPEED_SWIMBACK) and (prev > 1.5) then
            prev = 1.0
        end
        -- Speed Exploit Guard: Only send speed updates if the speed has actually changed
        local ok, currentSpeed = pcall(function() return player:GetSpeed(stype) end)
        if ok and currentSpeed ~= prev then
            SafeSetSpeed(player, stype, prev)
        end
    end
    -- Remove boots flame visual
    pcall(function() player:RemoveAura(SPELL_BOOTS_FLAMES) end)
end

--- Apply the charge-flight speed (run only; everything else left alone).
local function ApplyChargeSpeed(player, spellId)
    local speed = CHARGE_RUN_SPEED
    if spellId == SPELL_INTERCEPT then
        speed = CHARGE_RUN_SPEED_INTERCEPT
    end
    SafeSetSpeed(player, SPEED_RUN, speed)
end

-- =============================================================================
--  §4  GEOMETRY & NAVIGATION VALIDATION ENGINE
--
--  This is the heart of the "smart" system.  All checks happen BEFORE any
--  movement is issued so we never start a movement we can't complete safely.
-- =============================================================================

--- Check whether a point is above the "void" threshold.
local function IsVoidPoint(x, y, z)
    return z < VOID_THRESHOLD_Z
end

--- Attempt to get the floor Z at (x, y) using the map's height lookup.
--  TrinityCore exposes this through the Map object reachable from the player.
--  Returns (floorZ, success).
local function GetFloorZ(player, x, y, z)
    -- GetMap():GetHeight(x, y, z) is the preferred TC/Eluna call.
    -- We wrap in pcall because:
    --   a) The map might not be loaded in that tile.
    --   b) Some Eluna forks spell the method differently.
    local ok, result = pcall(function()
        local map = player:GetMap()
        if not map then return nil end
        -- GetHeight(x, y, z [, checkVmap]) – checkVmap=true includes vmaps
        return map:GetHeight(x, y, z, true)
    end)
    if ok and result and result > VOID_THRESHOLD_Z then
        return result, true
    end
    -- Fallback: use the player's current Z as a reference if we can't query
    return z, false
end

--- Validate that a destination coordinate is safe to land on.
--  Returns (safeX, safeY, safeZ, isSafe) where the XYZ may be adjusted.
local function ValidateDestination(player, px, py, pz, dx, dy, dz)
    -- 1. Hard void check
    if IsVoidPoint(dx, dy, dz) then
        DBG(player, "Destination rejected: void Z=" .. tostring(dz))
        return dx, dy, dz, false
    end

    -- 2. Get floor at destination
    local floorZ, floorOk = GetFloorZ(player, dx, dy, dz)

    -- 3. If the requested Z is far below the navigable floor, clamp upward.
    --    This catches "charging down a cliff" scenarios where MMaps would walk
    --    the player off the edge and drop them.
    if floorOk then
        local zDelta = dz - floorZ
        if zDelta < -MAX_Z_FALL_DELTA then
            DBG(player, "Clamping Z: dest=" .. tostring(dz) ..
                        " floor=" .. tostring(floorZ))
            dz = floorZ + MIN_Z_ABOVE_GROUND
        elseif zDelta < 0 then
            -- Destination is slightly below floor – bring it to floor level
            dz = floorZ + MIN_Z_ABOVE_GROUND
        end
    end

    -- 4. Also validate that the source player is not underground
    local srcFloor, srcOk = GetFloorZ(player, px, py, pz)
    if srcOk and (pz - srcFloor) < -1.0 then
        -- Player is under terrain (e.g. fell through after lag). Abort charge.
        DBG(player, "Source player is underground – aborting charge.")
        return dx, dy, dz, false
    end

    -- 5. Final void re-check after clamping
    if IsVoidPoint(dx, dy, dz) then
        return dx, dy, dz, false
    end

    return dx, dy, dz, true
end

--- Check Line-of-Sight between player and target using TC's vmap system.
--  Returns true if LoS is clear (or if the API is unavailable – fail open).
local function CheckLOS(player, tx, ty, tz)
    local ok, los = pcall(function()
        return player:IsInLineOfSight(tx, ty, tz)
    end)
    if not ok then return true end  -- API missing: assume clear
    return los
end

--- Generate alternative landing points when LoS is blocked or destination
--  is unsafe.  Returns a table of {x, y, z} candidates.
--
--  Strategy: project a set of points along an arc between the player and
--  the target, at decreasing distances, at small angular offsets.
--  Uses an upgraded VMAP-proportional tangent solver to curve around obstacles.
local function GenerateAlternatives(player, px, py, pz, tx, ty, tz)
    if type(player) == "number" then
        tz = ty
        ty = tx
        tx = pz
        pz = py
        py = px
        px = player
        player = nil
    end

    local candidates = {}
    local dx, dy, len = Normalise2D(tx - px, ty - py)
    if len < 0.001 then return candidates end

    -- 1. Probe the direct vector to find any collision/obstruction using real VMAPs
    local collisionStep = nil
    if player and type(player) == "userdata" then
        -- Adaptive stepping for maximum server performance and zero CPU overhead:
        -- Shorter distances do fewer VMAP checks (min 3 checks, max 5 checks)
        local steps = 5
        if len < 10.0 then
            steps = 3
        elseif len < 20.0 then
            steps = 4
        end

        for i = 1, steps do
            local frac = i / steps
            local sx = px + (tx - px) * frac
            local sy = py + (ty - py) * frac
            local sz = Lerp(pz, tz, frac)
            if not CheckLOS(player, sx, sy, sz) then
                collisionStep = i
                break
            end
        end
        -- Adjust collisionStep to be proportional to our steps count
        if collisionStep then
            collisionStep = (collisionStep / steps) * 5
        end
    end

    -- 2. Build prioritized angle set (using VMAP Proportional Solver if obstructed)
    local angles = {}
    local seen = {}
    local function addAngle(ang)
        -- Group angles to the nearest 0.05 radians (~3 degrees) to avoid duplicates and redundant checks
        local rounded = math.floor(ang * 20 + 0.5) / 20
        if not seen[rounded] then
            seen[rounded] = true
            table.insert(angles, ang)
        end
    end

    if collisionStep then
        -- We found a collision! Calculate collision distance
        local collisionDist = math.max(1.0, len * (collisionStep / 5))

        -- Standard VMAP obstacle width proportions in World of Warcraft:
        -- w = 3.0: Standard Arena columns, pillars, trees
        -- w = 5.0: Medium fences, crates, gravestones, rubble
        -- w = 8.0: Large building walls, ruins, solid barriers
        local widths = { 3.0, 5.0, 8.0 }

        for _, w in ipairs(widths) do
            local theta = math.atan2(w, collisionDist)
            if theta < 1.5 then -- Keep within reasonable perpendicular limits
                addAngle(theta)
                addAngle(-theta)
                addAngle(1.5 * theta)
                addAngle(-1.5 * theta)
            end
        end

        -- Add standard search angles as fallback
        for _, ang in ipairs({ 0, 0.25, -0.25, 0.5, -0.5, 0.75, -0.75 }) do
            addAngle(ang)
        end
    else
        -- No collision found, or missing player userdata. Use standard search angles.
        for _, ang in ipairs({ 0, 0.25, -0.25, 0.5, -0.5, 0.75, -0.75 }) do
            table.insert(angles, ang)
        end
    end

    -- 3. Distance fractions: try full range, then pull back
    local distFracs = { 1.0, 0.85, 0.70, 0.55 }

    for _, ang in ipairs(angles) do
        for _, frac in ipairs(distFracs) do
            local rdx, rdy = Rotate2D(dx * len * frac, dy * len * frac, ang)
            local cx = px + rdx
            local cy = py + rdy
            local cz = Lerp(pz, tz, frac)
            table.insert(candidates, { x = cx, y = cy, z = cz })
        end
    end
    return candidates
end

--- Pick the best safe landing point from a set of candidates.
--  Preference: closest to original target that passes all safety checks.
--  Returns (x, y, z, found).
local function FindSafeLandingPoint(player, px, py, pz, tx, ty, tz)
    local candidates = GenerateAlternatives(player, px, py, pz, tx, ty, tz)

    for _, c in ipairs(candidates) do
        local sx, sy, sz, safe = ValidateDestination(player, px, py, pz, c.x, c.y, c.z)
        if safe then
            local hasLOS = CheckLOS(player, sx, sy, sz)
            if hasLOS then
                return sx, sy, sz, true
            end
        end
    end

    -- Last resort: use the player's current position offset slightly toward target
    -- This guarantees we always return something, even if it's trivial.
    local ndx, ndy, _ = Normalise2D(tx - px, ty - py)
    return px + ndx * 2.0, py + ndy * 2.0, pz, false
end

--- Full navigation decision pipeline.
--  Given player and target positions, returns (destX, destY, destZ, quality)
--  where quality is: "direct", "adjusted", "fallback".
local function ResolveDestination(player, px, py, pz, tx, ty, tz)
    -- Step 1: Try the direct target position
    local dx, dy, dz, directSafe = ValidateDestination(player, px, py, pz, tx, ty, tz)
    local directLOS              = directSafe and CheckLOS(player, dx, dy, dz)

    if directSafe and directLOS then
        DBG(player, "Nav: direct path clear " .. FmtXYZ(dx, dy, dz))
        return dx, dy, dz, "direct"
    end

    -- Step 2: Try adjusted positions
    local ax, ay, az, found = FindSafeLandingPoint(player, px, py, pz, tx, ty, tz)
    if found then
        DBG(player, "Nav: adjusted path " .. FmtXYZ(ax, ay, az))
        return ax, ay, az, "adjusted"
    end

    -- Step 3: Fallback – short hop toward target to avoid doing nothing
    DBG(player, "Nav: fallback path")
    return ax, ay, az, "fallback"
end

-- =============================================================================
--  §5  RANGE VALIDATION
--  WotLK Charge rules:
--   - Minimum 8 yards  (cannot charge melee targets)
--   - Maximum 25 yards (rank 3 / intercept)
--   - Target must be in same map / phase
-- =============================================================================

--- Get the correct range cap for the spell being cast.
local function GetRangeCap(spellId)
    if spellId == SPELL_INTERCEPT then return 25.0 end
    if spellId == SPELL_INTERVENE  then return 25.0 end
    return 25.0  -- All charge ranks share the same max in 3.3.5a
end

--- Returns true if the 2-D distance is within [min, max].
local function IsInChargeRange(px, py, tx, ty, spellId)
    local d2 = DistSq2D(px, py, tx, ty)
    local mn  = CHARGE_RANGE_MIN * CHARGE_RANGE_MIN
    local mx  = GetRangeCap(spellId)
    mx = mx * mx
    return d2 >= mn and d2 <= mx
end

-- =============================================================================
--  §6  TARGET VALIDATION
-- =============================================================================

--- Comprehensive target checks before initiating a charge.
--  Returns (isValid, errorMsg).
local function ValidateTarget(player, target, spellId)
    if not target then
        return false, "No target selected."
    end
    if not target:IsInWorld() then
        return false, "Target is not in the world."
    end
    if not target:IsAlive() then
        return false, "Target is dead."
    end
    if target == player then
        return false, "Cannot charge yourself."
    end

    -- Phase check: player and target must be in the same phase
    -- (TC3.3.5a doesn't have GetPhase on all Eluna builds; guard it)
    local ok1, pp = pcall(function() return player:GetPhaseMask() end)
    local ok2, tp = pcall(function() return target:GetPhaseMask() end)
    if ok1 and ok2 and pp ~= tp then
        return false, "Target is in a different phase."
    end

    -- Map check
    local ok3, pm = pcall(function() return player:GetMapId() end)
    local ok4, tm = pcall(function() return target:GetMapId() end)
    if ok3 and ok4 and pm ~= tm then
        return false, "Target is on a different map."
    end

    -- Intervene: target must be a party member
    if spellId == SPELL_INTERVENE then
        local ok5, inGroup = pcall(function() return player:IsInGroup() end)
        if ok5 and not inGroup then
            return false, "Intervene requires a group member target."
        end
        -- Further group-member verification if API supports it
        local ok6, inSameGroup = pcall(function()
            return player:IsInSameGroupWith(target)
        end)
        if ok6 and not inSameGroup then
            return false, "Intervene target must be in your group."
        end
    end

    -- Intercept: requires Berserker Stance – skip if stance API unavailable
    if spellId == SPELL_INTERCEPT then
        -- Bug 9 fix: TC3 Eluna uses GetShapeshiftForm(), not GetStance().
        local ok7, stance = pcall(function() return player:GetShapeshiftForm() end)
        if ok7 and stance ~= 2 then  -- 2 = Berserker Stance in TC3
            return false, "Intercept requires Berserker Stance."
        end
    end

    -- Range check
    local px, py, pz = SafeGetLoc(player)
    local tx, ty, tz = SafeGetLoc(target)
    if not px or not tx then
        return false, "Could not determine positions."
    end
    if not IsInChargeRange(px, py, tx, ty, spellId) then
        return false, "Target out of charge range."
    end

    -- Immune / unattackable (for hostile charges)
    if spellId ~= SPELL_INTERVENE then
        -- Bug 12 fix: player:IsValidAttackTarget(target) is not a valid Eluna
        -- 3.3.5a API.  Use player:IsFriendlyTo(target) inverted instead.
        local ok8, friendly = pcall(function()
            return player:IsFriendlyTo(target)
        end)
        if ok8 and friendly then
            return false, "Target is not attackable."
        end
    end

    return true, nil
end

-- =============================================================================
--  §7  RAGE / BUFF EFFECTS ON LANDING
-- =============================================================================

--- Determine how much rage to grant based on spell.
local function GetRageGrant(spellId)
    if spellId == SPELL_INTERCEPT  then return RAGE_ON_INTERCEPT end
    if spellId == SPELL_INTERVENE  then return RAGE_ON_INTERVENE end
    return RAGE_ON_CHARGE
end

--- Determine which stun aura to apply.
local function GetStunAura(spellId)
    if spellId == SPELL_INTERCEPT then return AURA_INTERCEPT_STUN end
    if spellId == SPELL_INTERVENE  then return nil end  -- Intervene: no stun
    return AURA_CHARGE_STUN
end

--- Safely grant rage using the correct Eluna API.
local function GrantRage(player, amount)
    if amount <= 0 then return end
    -- Try ModifyPower first (canonical for 3.3.5a Eluna)
    local ok = pcall(function()
        player:ModifyPower(POWER_RAGE, amount)
    end)
    if not ok then
        -- Some forks expose AddRage directly
        pcall(function() player:AddRage(amount) end)
    end
end

