-- Zone / area IDs (WotLK 3.3.5a)
local ZONE_CHARGE_MODIFIERS = {
    -- Icecrown Citadel interior: limited vision, tricky LoS
    [4812] = { losRequired = true,  rangeScale = 0.9 },
    -- Dalaran Sewers arena
    [4406] = { losRequired = true,  rangeScale = 1.0 },
