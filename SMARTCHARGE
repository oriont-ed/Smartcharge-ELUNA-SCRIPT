-- =============================================================================
--  §39  INTERVENE SPECIAL LOGIC
--  Intervene teleports the warrior to intercept an incoming attack on an ally.
--  This requires special "interception point" calculation.
-- =============================================================================

--- Calculate the optimal interception point between the warrior's ally
--  (target) and whoever is attacking that ally (the attacker).
--  Returns (ix, iy, iz) – the interception position.
local function CalcInterceptPoint(px, py, pz, ax, ay, az, tx, ty, tz)
    -- Place the warrior just in front of the ally, facing the attacker.
    -- Direction: from attacker toward ally
    local dx, dy, len = Normalise2D(tx - ax, ty - ay)
    if len < 0.001 then
        return tx, ty, tz  -- Degenerate case: warrior at same spot as ally
    end
    -- Stand 1.5 yards in front of the ally toward the attacker
    local ix = tx - dx * 1.5
    local iy = ty - dy * 1.5
    local iz = tz
    return ix, iy, iz
end

--- Attempt to find the attacker of the target for smart Intervene placement.
local function GetTargetAttacker(target)
    if not target or not target:IsInWorld() then return nil end
    -- GetVictim() returns the unit the target is currently attacking
    local ok, attacker = pcall(function() return target:GetVictim() end)
    if ok and attacker and attacker:IsInWorld() then return attacker end
    return nil
end

-- =============================================================================
--  §40  STANCE-CHANGE EVENT INTEGRATION
--  In WotLK, stance changes can interrupt charges.  We hook stance change
--  to abort in-flight charges when the warrior switches out of combat stance.
-- =============================================================================

-- PLAYER_EVENT_ON_UPDATE_ZONE = 28  (zone/area change – conservative trigger)
-- There's no direct stance-change event in Eluna 3.x; we use the update loop.

-- Stance IDs for WotLK warrior
local STANCE_BATTLE       = 1
local STANCE_BERSERKER    = 2
local STANCE_DEFENSIVE    = 3

--- Check if the player's stance is valid for the active charge spell.
local function IsStanceValidForCharge(player, spellId)
    -- Bug 9 fix: GetShapeshiftForm() is the correct TC3 Eluna API.
    local ok, stance = pcall(function() return player:GetShapeshiftForm() end)
    if not ok then return true end  -- Assume valid if API missing

    if spellId == SPELL_INTERCEPT then
        return stance == STANCE_BERSERKER
    end
    if spellId == SPELL_CHARGE then
        return stance == STANCE_BATTLE
    end
    return true
end

-- Check stance validity during the arrival poll
-- (patched into OnArrivalTick via a wrapper)
local _origOnArrivalTick = OnArrivalTick
OnArrivalTick = function(eventId, delay, calls, player, state, target)
    if state and state.active and state.spellId then
        if not IsStanceValidForCharge(player, state.spellId) then
            AbortCharge(player, state, "stance changed mid-charge")
            StateRemove(player)
            RecordMetric("timeoutAborts")
            return
        end
    end
    _origOnArrivalTick(eventId, delay, calls, player, state, target)
end

